__pycache__/
*.pyc
*.pyo
.venv/
.venv-ci/
venv/
.DS_Store
.idea/
.vscode/

# Coverage + scanner artifacts (regenerated by CI)
.coverage
coverage.xml
htmlcov/
.pytest_cache/
.scannerwork/
dist/
muninn-bundle.tar.gz

# Generated: web parser is copied from root muninn.py (serve.py on startup, CI pages.yml on deploy)
web/muninn.py

# Generated outputs from converter
*.wdgwars.json
*.wdgwars.json.bak

# User input/output folders — keep the dirs + READMEs but ignore captures
input/*
output/*
!input/README.md
!output/README.md

# Watch-mode state file
.adsb-state.json

# Never commit captured/secret data
api.key
*.key
.env
.env.local

# Keep example files (whitelisted after the *.json deny)
*.json
!examples/*.json
!web/gungnir/*.json
!parity-fixtures/**/*.json

# Generated: synthetic sqb fixture is rebuilt in place by tests/test_sqb_input.py
